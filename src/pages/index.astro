---
import '../styles/landing.css';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>panchito · Autonomous E2E QA</title>
<meta name="description" content="panchito reads your change, writes the Playwright tests for what could break, and runs them against your live site — before you've opened the PR." />
<meta name="theme-color" content="#1b1a16" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>
<!-- ═══ NAV ═══════════════════════════════════════════════════════════ -->
<header class="nav" id="nav">
  <div class="nav__inner">
    <a class="nav__brand" href="#top" aria-label="Panchito home">
      <img src="/assets/panchito-mark.svg" alt="">
      <span class="nav__word">panchito</span>
    </a>
    <nav class="nav__links" aria-label="Sections">
      <a class="nav__link" href="#demo-1" data-i18n="nav.how">how it works</a>
      <a class="nav__link" href="#engine" data-i18n="nav.engine">live engine</a>
      <a class="nav__link" href="#compare" data-i18n="nav.compare">compare</a>
    </nav>
    <div class="nav__right">
      <a class="nav__link" href="/dashboard" style="font-weight:600" data-i18n="nav.console">console</a>
      <div class="lang" role="group" aria-label="Language">
        <button data-lang="en" aria-pressed="true">EN</button>
        <button data-lang="es" aria-pressed="false">ES</button>
      </div>
      <a class="icon-link" href="https://github.com/ArielFalcon/ai-pipeline" target="_blank" rel="noopener" aria-label="GitHub">
        <i data-lucide="github"></i>
      </a>
      <a class="btn btn--primary btn--sm" href="#engine" data-i18n="nav.cta">Run a scenario</a>
    </div>
  </div>
</header>

<main id="top">
  <!-- ═══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="band band--paper hero" id="hero">
    <div class="wrap hero__grid">
      <div class="hero__copy">
        <span class="kicker" data-i18n="hero.kicker">Autonomous E2E QA</span>
        <h1 class="display hero__h1" data-i18n="hero.h1">Tests every deploy. Trusts none of them.</h1>
        <p class="lede hero__sub" data-i18n="hero.sub">When a commit lands on your DEV environment, panchito reads the change, writes the Playwright tests for what could break, and runs them against the live site — before you've opened the PR.</p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="#engine"><i data-lucide="play" class="ic"></i><span data-i18n="hero.cta1">Run a live scenario</span></a>
          <a class="btn btn--ghost-ink" href="#demo-1"><span data-i18n="hero.cta2">See it work</span><i data-lucide="arrow-down" class="ic"></i></a>
        </div>
        <div class="hero__meta">
          <span><i data-lucide="git-merge" style="width:15px;height:15px"></i> <b data-i18n="hero.m1">triggers on merge to main</b></span>
          <span><i data-lucide="git-pull-request" style="width:15px;height:15px"></i> <b data-i18n="hero.m2">PRs into your own git</b></span>
          <span><i data-lucide="box" style="width:15px;height:15px"></i> <b data-i18n="hero.m3">open source</b></span>
        </div>
      </div>
      <div class="hero__visual">
        <div class="microdemo" id="hero-demo" aria-hidden="true">
          <div class="microdemo__head">
            <span class="dot3"><i></i><i></i><i></i></span>
            <span class="microdemo__title">panchito · watching</span>
          </div>
          <div id="hero-demo-body"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DEMO 1 — blast radius ═════════════════════════════════════ -->
  <section class="band band--dark ruled section" id="demo-1">
    <div class="wrap demo">
      <div class="demo__text">
        <span class="demo__num">01 · <span data-i18n="d1.tag">analysis</span></span>
        <span class="kicker" style="display:block;margin-top:10px" data-i18n="d1.kicker">Blast radius</span>
        <h2 class="section-title" data-i18n="d1.h2">It doesn't test everything. It tests what your change can break.</h2>
        <p class="lede demo__sub" data-i18n="d1.sub">panchito maps your code — across every repo, frontend to microservices — into a dependency graph. When a commit lands, it grows the blast radius through real relationships: a class you changed, injected three services away, still lights up. Then it writes a focused test plan — before running a single test.</p>
        <p class="demo__caption"><b data-i18n="d1.capk">Default: diff</b> <span data-i18n="d1.cap">(blast radius of one change). Also: manual (test what you ask) · complete (audit the whole suite).</span></p>
        <div class="demo__replay"><button class="btn btn--ghost-dark btn--sm" data-replay="demo1"><i data-lucide="rotate-cw" class="ic"></i><span data-i18n="replay">Replay</span></button></div>
      </div>
      <div class="demo__stage">
        <div class="fig-label">FIG. 01 · dependency graph<span class="fig-label__rule"></span></div>
        <div class="stage-surface" id="stage-1"></div>
      </div>
    </div>
  </section>

  <!-- ═══ DEMO 2 — generate→review→coverage→run→record ═════════════ -->
  <section class="band band--dark ruled section" id="demo-2">
    <div class="wrap demo demo--flip">
      <div class="demo__text">
        <span class="demo__num">02 · <span data-i18n="d2.tag">the full flow</span></span>
        <span class="kicker" style="display:block;margin-top:10px" data-i18n="d2.kicker">Proof, not green</span>
        <h2 class="section-title" data-i18n="d2.h2">A test that runs green isn't proof. panchito proves it.</h2>
        <p class="lede demo__sub" data-i18n="d2.sub">It writes the spec, a different model reviews it for real assertions, and change-coverage confirms the test actually executes the lines you changed. Then it runs against your live DEV and tells you — in plain language — what broke. Green and approved → a PR into your repo. Broken → a GitHub Issue. Your tests, your git, no lock-in.</p>
        <div class="demo__caption" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <span data-i18n="d2.ending">Ending:</span>
          <span class="toggle-end" role="group" aria-label="Ending">
            <button data-ending="pass" aria-pressed="false" data-i18n="d2.green">green → PR</button>
            <button data-ending="fail" aria-pressed="true" data-i18n="d2.red">broken → Issue</button>
          </span>
        </div>
        <div class="demo__replay"><button class="btn btn--ghost-dark btn--sm" data-replay="demo2"><i data-lucide="rotate-cw" class="ic"></i><span data-i18n="replay">Replay</span></button></div>
      </div>
      <div class="demo__stage">
        <div class="fig-label">FIG. 02 · generate → verify → record<span class="fig-label__rule"></span></div>
        <div class="stage-surface" id="stage-2"></div>
      </div>
    </div>
  </section>

  <!-- ═══ DEMO 3 — ask it anything (paper) ═════════════════════════ -->
  <section class="band band--paper-2 section" id="demo-3">
    <div class="wrap demo">
      <div class="demo__text">
        <span class="demo__num">03 · <span data-i18n="d3.tag">memory + chat</span></span>
        <span class="kicker" style="display:block;margin-top:10px" data-i18n="d3.kicker">Ask it anything</span>
        <h2 class="section-title" data-i18n="d3.h2">Your test suite, now something you can talk to.</h2>
        <p class="lede demo__sub" data-i18n="d3.sub">panchito remembers every run — fragile flows, flaky selectors, what fixed them last time — and answers from memory. Trigger runs, explain failures, onboard a repo: in plain language.</p>
        <p class="demo__caption"><b data-i18n="d3.try">Live · switch channels or tap an action.</b></p>
        <div class="demo__replay"><button class="btn btn--ghost-ink btn--sm" data-replay="demo3"><i data-lucide="rotate-cw" class="ic"></i><span data-i18n="replay">Replay</span></button></div>
      </div>
      <div class="demo__stage">
        <div class="fig-label">FIG. 03 · any channel<span class="fig-label__rule"></span></div>
        <div class="stage-surface" id="stage-3"></div>
      </div>
    </div>
  </section>

  <!-- ═══ DEMO 4 — it tests itself ═════════════════════════════════ -->
  <section class="band band--dark ruled section" id="demo-4">
    <div class="wrap demo demo--flip">
      <div class="demo__text">
        <span class="demo__num">04 · <span data-i18n="d4.tag">recursive</span></span>
        <span class="kicker" style="display:block;margin-top:10px" data-i18n="d4.kicker">It tests itself</span>
        <h2 class="section-title" data-i18n="d4.h2">The first thing panchito tests is panchito.</h2>
        <p class="lede demo__sub" data-i18n="d4.sub">Its agents report their own failures to a maintainer agent that fixes them and commits the change — with live log and status monitoring. The code that uses itself to get better, every day. (Like building git in git.)</p>
        <div class="demo__replay"><button class="btn btn--ghost-dark btn--sm" data-replay="demo4"><i data-lucide="rotate-cw" class="ic"></i><span data-i18n="replay">Replay</span></button></div>
      </div>
      <div class="demo__stage">
        <div class="fig-label">FIG. 04 · self-fix loop<span class="fig-label__rule"></span></div>
        <div class="stage-surface" id="stage-4"></div>
      </div>
    </div>
  </section>

  <!-- ═══ SCENARIO ENGINE ══════════════════════════════════════════ -->
  <section class="band band--dark ruled section" id="engine">
    <div class="wrap">
      <div class="engine__head">
        <span class="kicker" data-i18n="eng.kicker">Live engine</span>
        <h2 class="section-title" data-i18n="eng.h2">Don't take our word for it. Run it.</h2>
        <p class="lede engine__lede" data-i18n="eng.sub">Point it at a repo, pick how deep to look, and watch the whole pipeline work — live.</p>
      </div>
      <div class="engine__panel">
        <div class="engine__controls">
          <div class="ctl">
            <label class="ctl__label" for="eng-repo" data-i18n="eng.repo">Repository</label>
            <div class="ctl__input">
              <i data-lucide="github" style="width:16px;height:16px"></i>
              <input id="eng-repo" type="text" value="your-org/shop" spellcheck="false">
            </div>
          </div>
          <div class="ctl">
            <label class="ctl__label" data-i18n="eng.depth">Analyze the last N commits</label>
            <div class="stepper" role="group" aria-label="Diff depth">
              <button id="depth-dec" aria-label="decrease">−</button>
              <span class="stepper__val" id="depth-val">10</span>
              <button id="depth-inc" aria-label="increase">+</button>
            </div>
          </div>
          <div class="ctl__or" data-i18n="eng.or">— or —</div>
          <label class="ctl" style="cursor:pointer;flex-direction:row;align-items:center;gap:10px">
            <input type="checkbox" id="eng-full" style="accent-color:var(--brand);width:16px;height:16px">
            <span class="ctl__label" style="text-transform:none;letter-spacing:0" data-i18n="eng.full">Full analysis — audit the whole repo</span>
          </label>
          <button class="btn btn--primary" id="eng-run" style="height:46px"><i data-lucide="play" class="ic"></i><span data-i18n="eng.run">Run pipeline</span></button>
          <div class="cap-note">
            <i data-lucide="info" style="width:15px;height:15px"></i>
            <span data-i18n="eng.cap">Demo mode is capped — a few commits, a handful of tests — so you get the feel in seconds, not an 80-test marathon.</span>
          </div>
        </div>
        <div class="engine__stage">
          <div class="rail" id="eng-rail"></div>
          <div class="divider-rule" style="background:var(--line)"></div>
          <div class="engine__output" id="eng-output">
            <div class="engine__empty" id="eng-empty">
              <i data-lucide="terminal-square"></i>
              <span class="mono" style="font-size:12.5px" data-i18n="eng.idle">configure a run and press play</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ COMPARISON ═══════════════════════════════════════════════ -->
  <section class="band band--paper section" id="compare">
    <div class="wrap">
      <span class="kicker" data-i18n="cmp.kicker">Where it's different</span>
      <h2 class="section-title" data-i18n="cmp.h2">Built for the part no one else proves.</h2>
      <p class="lede" style="margin-top:14px" data-i18n="cmp.sub">Honest about what's table stakes — and where panchito stands alone.</p>
      <div class="cmp__scroll" style="margin-top:34px">
        <table class="cmp">
          <colgroup><col><col class="us"><col><col><col><col></colgroup>
          <thead>
            <tr>
              <th></th>
              <th class="is-us">panchito</th>
              <th>QA Wolf</th>
              <th>Octomind</th>
              <th>Meticulous</th>
              <th>Ranger</th>
            </tr>
          </thead>
          <tbody id="cmp-body"></tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ FINAL CTA ════════════════════════════════════════════════ -->
  <section class="band band--dark ruled section" id="cta">
    <div class="wrap cta">
      <span class="kicker" data-i18n="cta.kicker">Get started</span>
      <h2 class="section-title" data-i18n="cta.h2">Run it on your real repo.</h2>
      <p class="lede" style="margin:14px auto 0" data-i18n="cta.sub">panchito is open source. Self-host the engine, or join the waitlist for the hosted beta.</p>
      <form class="cta__form" id="waitlist" novalidate>
        <label class="cta__email">
          <i data-lucide="mail" style="width:16px;height:16px;color:var(--muted)"></i>
          <input type="email" id="wl-email" placeholder="you@team.dev" data-i18n-ph="cta.ph" aria-label="Email">
        </label>
        <button class="btn btn--primary" type="submit" style="height:46px" data-i18n="cta.join">Join the waitlist</button>
        <a class="btn btn--ghost-dark" href="https://github.com/ArielFalcon/ai-pipeline" target="_blank" rel="noopener" style="height:46px"><i data-lucide="github" class="ic"></i><span data-i18n="cta.gh">Star on GitHub</span></a>
      </form>
      <p class="cta__ok" id="wl-ok" data-i18n="cta.ok">✓ you're on the list — we'll be in touch.</p>
      <p class="cta__note" data-i18n="cta.note"><!-- TODO: wire form endpoint --> no backend in this demo — submission is stored locally.</p>
    </div>
  </section>
</main>

<!-- ═══ FOOTER ═══════════════════════════════════════════════════════ -->
<footer class="band band--dark footer">
  <div class="wrap footer__inner">
    <div class="footer__brand">
      <img src="/assets/panchito-mark-light.svg" alt="">
      <span class="footer__word">panchito</span>
    </div>
    <nav class="footer__links" aria-label="Footer">
      <a href="https://github.com/ArielFalcon/ai-pipeline" target="_blank" rel="noopener">GitHub</a>
      <a href="/dashboard" data-i18n="nav.console">console</a>
      <a href="#demo-1" data-i18n="nav.how">how it works</a>
      <a href="#engine" data-i18n="nav.engine">live engine</a>
    </nav>
    <div style="display:flex;align-items:center;gap:16px">
      <div class="lang" role="group" aria-label="Language">
        <button data-lang="en" aria-pressed="true">EN</button>
        <button data-lang="es" aria-pressed="false">ES</button>
      </div>
      <span class="footer__wink" data-i18n="footer.wink">made with panchito</span>
    </div>
  </div>
</footer>

<script is:inline src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.js"></script>
<script is:inline src="/landing/i18n.js"></script>
<script is:inline src="/landing/player.js"></script>
<script is:inline src="/landing/scenarios.js"></script>
<script is:inline src="/landing/app.js"></script>
</body>
</html>
